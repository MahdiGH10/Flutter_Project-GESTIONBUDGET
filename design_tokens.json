    "screenSize": {
      "width": 375,
      "height": 812
    }
  },
  "colors": {
    "primary": {
      "900": "#1F2C37",
      "800": "#2A3B47",
      "700": "#354A56",
      "100": "#F7F9FC",
      "50": "#FAFBFC"
    },
    "success": {
      "500": "#4CD964",
      "400": "#6EE084",
      "100": "#E8F9EC",
      "50": "#F3FDF5"
    },
    "danger": {
      "500": "#FF3B30",
      "400": "#FF6B63",
      "100": "#FFE8E7",
      "50": "#FFF3F2"
    },
    "neutral": {
      "900": "#1F2C37",
      "700": "#3D4F5F",
